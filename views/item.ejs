<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doodads - <%= item.name %></title>
    <link rel="stylesheet" href="styles/doodad-style.css">
    <link rel="icon" href="images/Blue_square_D.PNG">
</head>
<body>
  <header>
    <!-- Navigation Bar -->
    <%- include('partials/nav') %>
  </header>
    

    <div class="listing">
      <div class="showcase">
        <img src=<%= item.img.substring(6) %> alt="main picture">
      </div>
      <br>
      <h2><%= item.name %></h2>
      <h1 class="listing-price">$<%= item.price %></h1>
      
      <h4>Desctiption: </h4>
      <p><%= item.item_desc %></p>
      <% if(item.sold == 0) { %>
        <% const link = "/item-purchesed?id=" + item.id; %>
        <a href=<%= link %>><button>Buy</button></a>
      <% } %>
    </div>
    
</body>
</html>